# Public map configuration for local development
# Copy this file to .env.local and adjust as needed.

# Chart source mode: pmtiles (default) or xyz
NEXT_PUBLIC_NAUTICAL_CHART_SOURCE_MODE=pmtiles

# PMTiles archive URL used when source mode is pmtiles
NEXT_PUBLIC_NAUTICAL_CHART_PMTILES_URL=http://localhost:8081/ncds_20c.pmtiles

# XYZ tile template used when source mode is xyz
# Supports either {z}/{x}/{y} templates or {bbox-epsg-3857}
NEXT_PUBLIC_NAUTICAL_CHART_TILE_URL=

# Optional attribution override for chart source
NEXT_PUBLIC_NAUTICAL_CHART_ATTRIBUTION=

# Optional glyph endpoint for MapLibre text rendering
NEXT_PUBLIC_MAPLIBRE_GLYPHS_URL=
