{
  "name": "reciprocal-clubs",
  "version": "0.0.1",
  "description": "STYC reciprocal club geodata and Next.js application",
  "license": "MIT",
  "author": "Ivan Storck",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:data": "node validate.cjs",
    "export:kml": "node geojson-to-kml.cjs",
    "prepare": "panda codegen && panda cssgen --outfile styled-system/styles.css"
  },
  "dependencies": {
    "@ark-ui/react": "^4.9.1",
    "maplibre-gl": "^5.9.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.3",
    "@pandacss/preset-panda": "^0.53.7",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^27.0.1",
    "markdownlint-cli": "^0.49.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.10"
  }
}
