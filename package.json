{
  "name": "reciprocal-clubs",
  "version": "0.0.1",
  "description": "STYC reciprocal club geodata and Next.js application",
  "license": "MIT",
  "author": "Ivan Storck",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:data": "node validate.cjs",
    "export:kml": "node geojson-to-kml.cjs",
    "nautical:pmtiles:convert:ncds": "mkdir -p data/nautical-charts/pmtiles && pmtiles convert data/ncds_20c.mbtiles data/nautical-charts/pmtiles/ncds_20c.pmtiles",
    "nautical:pmtiles:convert": "mkdir -p data/nautical-charts/pmtiles && for r in 04 05 06 07 08 09 10; do pmtiles convert data/nautical-charts/mbtiles/MBTILES_${r}.mbtiles data/nautical-charts/pmtiles/MBTILES_${r}.pmtiles; done",
    "nautical:pmtiles:merge": "pmtiles merge data/nautical-charts/pmtiles/MBTILES_04.pmtiles data/nautical-charts/pmtiles/MBTILES_05.pmtiles data/nautical-charts/pmtiles/MBTILES_06.pmtiles data/nautical-charts/pmtiles/MBTILES_07.pmtiles data/nautical-charts/pmtiles/MBTILES_08.pmtiles data/nautical-charts/pmtiles/MBTILES_09.pmtiles data/nautical-charts/pmtiles/MBTILES_10.pmtiles data/nautical-charts/pmtiles/noaa_regions_04_10.pmtiles",
    "nautical:pmtiles:serve": "pmtiles serve data/nautical-charts/pmtiles --port 8081",
    "nautical:pmtiles:upload:r2": "bash scripts/upload-pmtiles-to-r2.sh",
    "prepare": "panda codegen"
  },
  "dependencies": {
    "@ark-ui/react": "^4.9.1",
    "maplibre-gl": "^5.9.0",
    "next": "^16.0.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^0.53.7",
    "@pandacss/preset-panda": "^0.53.7",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^27.0.1",
    "markdownlint-cli": "^0.49.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.10"
  }
}
