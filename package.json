{
  "name": "reciprocal-clubs",
  "version": "1.0.4",
  "description": "STYC reciprocal club geodata and Next.js application",
  "license": "MIT",
  "author": "Ivan Storck",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run nautical:pmtiles:serve\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:data": "node validate.cjs",
    "export:kml": "node geojson-to-kml.cjs",
    "nautical:pmtiles:convert": "mkdir -p data/nautical-charts/pmtiles data/nautical-charts/mbtiles && for f in data/nautical-charts/mbtiles/ncds_*.mbtiles; do [ -f \"$f\" ] || continue; name=$(basename \"$f\" .mbtiles); pmtiles convert \"$f\" \"data/nautical-charts/pmtiles/${name}.pmtiles\" || exit 1; done",
    "nautical:pmtiles:merge": "pmtiles merge data/nautical-charts/pmtiles/ncds_*.pmtiles data/nautical-charts/pmtiles/noaa_pnw.pmtiles",
    "nautical:pmtiles:serve": "pmtiles serve data/nautical-charts/pmtiles --port 8081",
    "nautical:pmtiles:upload:r2": "bash scripts/upload-pmtiles-to-r2.sh",
    "release": "semantic-release",
    "prepare": "panda codegen && husky"
  },
  "dependencies": {
    "@ark-ui/react": "^4.9.1",
    "maplibre-gl": "^5.9.0",
    "next": "^16.0.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@pandacss/dev": "^1.11.3",
    "@pandacss/preset-panda": "^1.11.3",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.0.0",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.49.0",
    "semantic-release": "25.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
